{
  "name": "trading-automation-control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check:imports": "node scripts/check-case-sensitive-imports.js",
    "lint": "eslint src/ scripts/ test/ --max-warnings 100",
    "test": "node scripts/check-case-sensitive-imports.js && npm run lint && node scripts/run-tests.js",
    "ci": "node scripts/check-case-sensitive-imports.js && eslint src/ scripts/ test/ --max-warnings 0 && node scripts/run-tests.js",
    "test:pipeline": "node --test --test-concurrency=1 test/live-policy-file.test.js test/trading-pipeline.test.js test/stock-scanner-launcher.test.js test/stock-scanner.test.js",
    "policy:migrate": "node scripts/migrate-live-policy.js",
    "replay": "node src/replay-cli.js",
    "start": "node src/minimal-cli.js",
    "start:market": "node scripts/start-stock-scanner.js",
    "dashboard:mobile:start": "powershell -ExecutionPolicy Bypass -File scripts/start-mobile-dashboard.ps1",
    "dashboard:mobile:serve": "powershell -ExecutionPolicy Bypass -File scripts/serve-dashboard-tailscale.ps1",
    "dashboard:mobile:check": "powershell -ExecutionPolicy Bypass -File scripts/check-mobile-dashboard.ps1",
    "dashboard": "node scripts/dashboard-cli.js",
    "workflow": "node scripts/workflow.js start",
    "workflow:stop": "node scripts/workflow.js stop",
    "workflow:restart": "node scripts/workflow.js restart",
    "workflow:status": "node scripts/workflow.js status",
    "pulse": "node scripts/workflow-pulse.js",
    "test:workflow": "node --test --test-concurrency=1 test/workflow-supervisor.test.js test/process-lock.test.js test/dashboard-control.test.js",
    "control": "node src/server-cli.js",
    "trader": "node src/minimal-cli.js",
    "live-market:automation": "node scripts/live-market-daily-start-stop.js",
    "regular-stock:automation": "node scripts/regular-stock-daily-start-stop.js",
    "regular-stock:automation:install": "powershell -ExecutionPolicy Bypass -File scripts/install-regular-stock-automation.ps1",
    "regular-stock:automation:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-regular-stock-automation.ps1",
    "preflight:live": "node scripts/live-preflight.js",
    "reconcile:broker": "node scripts/reconcile-broker-local.js",
    "scanner:validate-selection": "node src/scanner-selection-validation.js",
    "scanner:update-outcomes": "node src/scanner-selection-outcomes-cli.js",
    "smoke:live": "node scripts/live-minimal-paper-smoke.js",
    "status:overnight": "node scripts/overnight-status.js",
    "tune:policy": "node src/policy-cli.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0"
  }
}
